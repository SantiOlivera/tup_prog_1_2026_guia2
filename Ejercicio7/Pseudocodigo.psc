Proceso MayorValor
	Definir num,mayor Como Real;
	Escribir 'Ingrese los 5 valores';
	Leer num;
	mayor <- num;
	Leer num;
	Si (num>mayor) Entonces
		mayor <- num;
	FinSi
	Leer num;
	Si (num>mayor) Entonces
		mayor <- num;
	FinSi
	Leer num;
	Si (num>mayor) Entonces
		mayor <- num;
	FinSi
	Leer num;
	Si (num>mayor) Entonces
		mayor <- num;
	FinSi
	Escribir 'El mayor es ',mayor;
FinProceso
